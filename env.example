# GenLayer Node Monitor - Environment Variables
# Copy this file to .env and fill in your values
# Usage: source .env

# -----------------------------------------------
# Node Configuration
# -----------------------------------------------
# Password used when running genlayernode
GENLAYER_PASSWORD=your_node_password_here

# -----------------------------------------------
# LLM Provider API Keys (choose one or more)
# -----------------------------------------------
# Heurist (free credits with referral code "genlayer")
# Sign up: https://dev-api-form.heurist.ai
HEURISTKEY=

# OpenAI
OPENAIKEY=

# Anthropic (Claude) - used by ai_analyzer.py
ANTHROPIC_API_KEY=

# Chutes
CHUTES_API_KEY=

# XAI
XAIKEY=

# Gemini
GEMINIKEY=

# -----------------------------------------------
# Monitor Settings (optional)
# -----------------------------------------------
# CHECK_INTERVAL=60        # seconds between health checks
# MAX_RESTART_ATTEMPTS=5   # max auto-restart attempts
